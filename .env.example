# Database (PostgreSQL - get free DB at neon.tech)
DATABASE_URL="postgresql://user:password@host:5432/syntra?sslmode=require"

# NextAuth
NEXTAUTH_SECRET="your-secret-key-min-32-chars-change-this"
NEXTAUTH_URL="http://localhost:3000"

# AWS S3 (for file uploads)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="ap-south-1"
AWS_S3_BUCKET="syntra-files"

# Resend (email)
RESEND_API_KEY=""
EMAIL_FROM="noreply@yourdomain.com"
