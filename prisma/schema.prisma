generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth & Users ────────────────────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  name           String
  email          String    @unique
  password       String?
  avatar         String?
  phone          String?
  jobTitle       String?
  employmentType String    @default("full-time")
  status         String    @default("active")
  startDate      DateTime?
  skills         String[]
  bio            String?
  departmentId   String?
  teamId         String?
  roleId         String
  managerId      String?

  role          Role        @relation(fields: [roleId], references: [id])
  department    Department? @relation(fields: [departmentId], references: [id])
  team          Team?       @relation(fields: [teamId], references: [id])
  manager       User?       @relation("Reports", fields: [managerId], references: [id])
  directReports User[]      @relation("Reports")

  accounts          Account[]
  sessions          Session[]
  attendance        Attendance[]
  leaves            Leave[]
  leaveBalances     LeaveBalance[]
  tasksAssigned     Task[]          @relation("Assignee")
  tasksReported     Task[]          @relation("Reporter")
  timeLogs          TimeLog[]
  ticketsRaised     Ticket[]        @relation("RaisedBy")
  ticketsAssigned   Ticket[]        @relation("AssignedTo")
  assets            Asset[]
  messages          Message[]
  notifications     Notification[]
  projectMembers    ProjectMember[]
  taskComments      TaskComment[]
  ticketComments    TicketComment[]
  wikiCreated       WikiPage[]      @relation("WikiCreatedBy")
  wikiUpdated       WikiPage[]      @relation("WikiUpdatedBy")
  filesUploaded     File[]
  foldersCreated    Folder[]
  recognitionsGiven Recognition[]   @relation("RecognitionFrom")
  recognitionsRecv  Recognition[]   @relation("RecognitionTo")
  pollVotes         PollVote[]
  announcements     Announcement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  permissions Json     @default("{}")
  users       User[]

  createdAt DateTime @default(now())
}

// ─── Organisation ─────────────────────────────────────────────────────────────

model Department {
  id            String         @id @default(cuid())
  name          String
  description   String?
  headId        String?
  users         User[]
  teams         Team[]
  leaves        Leave[]
  announcements Announcement[]
  files         File[]
  folders       Folder[]

  createdAt DateTime @default(now())
}

model Team {
  id           String     @id @default(cuid())
  name         String
  departmentId String
  leadId       String?
  department   Department @relation(fields: [departmentId], references: [id])
  users        User[]

  createdAt DateTime @default(now())
}

// ─── Attendance & Leave ───────────────────────────────────────────────────────

model Attendance {
  id       String    @id @default(cuid())
  userId   String
  date     DateTime  @db.Date
  clockIn  DateTime?
  clockOut DateTime?
  type     String    @default("office")
  notes    String?
  user     User      @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, date])
}

model Leave {
  id           String      @id @default(cuid())
  userId       String
  type         String
  startDate    DateTime    @db.Date
  endDate      DateTime    @db.Date
  daysCount    Float
  reason       String?
  status       String      @default("pending")
  approvedById String?
  approvedAt   DateTime?
  departmentId String?
  user         User        @relation(fields: [userId], references: [id])
  department   Department? @relation(fields: [departmentId], references: [id])

  createdAt DateTime @default(now())
}

model LeaveBalance {
  id          String @id @default(cuid())
  userId      String
  year        Int
  annualTotal Float  @default(20)
  annualUsed  Float  @default(0)
  sickTotal   Float  @default(10)
  sickUsed    Float  @default(0)
  user        User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, year])
}

model PublicHoliday {
  id        String   @id @default(cuid())
  name      String
  date      DateTime @db.Date
  country   String   @default("IN")

  createdAt DateTime @default(now())
}

// ─── Projects, Sprints & Tasks ────────────────────────────────────────────────

model Project {
  id          String          @id @default(cuid())
  name        String
  key         String          @unique
  description String?
  type        String          @default("scrum")
  status      String          @default("active")
  leadId      String?
  members     ProjectMember[]
  epics       Epic[]
  sprints     Sprint[]
  tasks       Task[]
  files       File[]
  folders     Folder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProjectMember {
  id        String  @id @default(cuid())
  projectId String
  userId    String
  role      String  @default("member")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@unique([projectId, userId])
}

model Epic {
  id          String    @id @default(cuid())
  projectId   String
  name        String
  description String?
  status      String    @default("open")
  startDate   DateTime?
  endDate     DateTime?
  color       String?
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks       Task[]

  createdAt DateTime @default(now())
}

model Sprint {
  id        String    @id @default(cuid())
  projectId String
  name      String
  goal      String?
  status    String    @default("planning")
  startDate DateTime?
  endDate   DateTime?
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks     Task[]

  createdAt DateTime @default(now())
}

model Task {
  id          String    @id @default(cuid())
  projectId   String
  sprintId    String?
  epicId      String?
  parentId    String?
  title       String
  description String?
  type        String    @default("task")
  status      String    @default("todo")
  priority    String    @default("medium")
  assigneeId  String?
  reporterId  String
  storyPoints Int?
  dueDate     DateTime?
  order       Int       @default(0)

  project     Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sprint      Sprint?          @relation(fields: [sprintId], references: [id])
  epic        Epic?            @relation(fields: [epicId], references: [id])
  parent      Task?            @relation("Subtasks", fields: [parentId], references: [id])
  subtasks    Task[]           @relation("Subtasks")
  assignee    User?            @relation("Assignee", fields: [assigneeId], references: [id])
  reporter    User             @relation("Reporter", fields: [reporterId], references: [id])
  comments    TaskComment[]
  attachments TaskAttachment[]
  timeLogs    TimeLog[]
  labels      TaskLabel[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TaskComment {
  id        String @id @default(cuid())
  taskId    String
  userId    String
  content   String
  task      Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model TaskAttachment {
  id         String @id @default(cuid())
  taskId     String
  fileName   String
  fileUrl    String
  fileSize   Int
  uploadedBy String
  task       Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model TimeLog {
  id          String   @id @default(cuid())
  taskId      String
  userId      String
  hours       Float
  description String?
  loggedDate  DateTime @db.Date
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model Label {
  id    String      @id @default(cuid())
  name  String
  color String
  tasks TaskLabel[]
}

model TaskLabel {
  taskId  String
  labelId String
  task    Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label   Label @relation(fields: [labelId], references: [id])

  @@id([taskId, labelId])
}

// ─── IT Ticketing / Service Desk ──────────────────────────────────────────────

model Ticket {
  id           String          @id @default(cuid())
  title        String
  description  String
  category     String
  priority     String          @default("medium")
  status       String          @default("open")
  raisedById   String
  assignedToId String?
  resolvedAt   DateTime?
  slaDeadline  DateTime?
  raisedBy     User            @relation("RaisedBy", fields: [raisedById], references: [id])
  assignedTo   User?           @relation("AssignedTo", fields: [assignedToId], references: [id])
  comments     TicketComment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TicketComment {
  id       String  @id @default(cuid())
  ticketId String
  userId   String
  content  String
  internal Boolean @default(false)
  ticket   Ticket  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user     User    @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

// ─── Communication ────────────────────────────────────────────────────────────

model Announcement {
  id           String      @id @default(cuid())
  title        String
  content      String
  departmentId String?
  pinned       Boolean     @default(false)
  createdById  String
  department   Department? @relation(fields: [departmentId], references: [id])
  createdBy    User        @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now())
}

model Channel {
  id        String          @id @default(cuid())
  name      String?
  type      String          @default("direct")
  createdBy String
  members   ChannelMember[]
  messages  Message[]

  createdAt DateTime @default(now())
}

model ChannelMember {
  channelId String
  userId    String
  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@id([channelId, userId])
}

model Message {
  id        String  @id @default(cuid())
  channelId String
  senderId  String
  content   String
  fileUrl   String?
  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  sender    User    @relation(fields: [senderId], references: [id])

  createdAt DateTime @default(now())
}

model Poll {
  id        String     @id @default(cuid())
  question  String
  options   String[]
  createdBy String
  endsAt    DateTime?
  votes     PollVote[]

  createdAt DateTime @default(now())
}

model PollVote {
  id          String @id @default(cuid())
  pollId      String
  userId      String
  optionIndex Int
  poll        Poll   @relation(fields: [pollId], references: [id], onDelete: Cascade)
  user        User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@unique([pollId, userId])
}

model Recognition {
  id         String  @id @default(cuid())
  fromUserId String
  toUserId   String
  message    String
  badge      String?
  fromUser   User    @relation("RecognitionFrom", fields: [fromUserId], references: [id])
  toUser     User    @relation("RecognitionTo", fields: [toUserId], references: [id])

  createdAt DateTime @default(now())
}

// ─── Files, Wiki & Assets ─────────────────────────────────────────────────────

model Folder {
  id           String      @id @default(cuid())
  name         String
  parentId     String?
  departmentId String?
  projectId    String?
  createdById  String
  parent       Folder?     @relation("SubFolders", fields: [parentId], references: [id])
  children     Folder[]    @relation("SubFolders")
  files        File[]
  department   Department? @relation(fields: [departmentId], references: [id])
  project      Project?    @relation(fields: [projectId], references: [id])
  createdBy    User        @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now())
}

model File {
  id           String      @id @default(cuid())
  name         String
  url          String
  size         Int
  mimeType     String
  folderId     String?
  departmentId String?
  projectId    String?
  uploadedById String
  folder       Folder?     @relation(fields: [folderId], references: [id])
  department   Department? @relation(fields: [departmentId], references: [id])
  project      Project?    @relation(fields: [projectId], references: [id])
  uploadedBy   User        @relation(fields: [uploadedById], references: [id])

  createdAt DateTime @default(now())
}

model WikiPage {
  id          String     @id @default(cuid())
  title       String
  content     String
  slug        String     @unique
  parentId    String?
  createdById String
  updatedById String?
  parent      WikiPage?  @relation("SubPages", fields: [parentId], references: [id])
  children    WikiPage[] @relation("SubPages")
  createdBy   User       @relation("WikiCreatedBy", fields: [createdById], references: [id])
  updatedBy   User?      @relation("WikiUpdatedBy", fields: [updatedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Asset {
  id           String    @id @default(cuid())
  name         String
  type         String
  serialNumber String?
  assignedToId String?
  assignedDate DateTime?
  status       String    @default("available")
  assignedTo   User?     @relation(fields: [assignedToId], references: [id])

  createdAt DateTime @default(now())
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id        String  @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  link      String?
  read      Boolean @default(false)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}
